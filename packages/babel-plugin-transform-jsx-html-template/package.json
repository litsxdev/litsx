{
  "name": "@litsx/babel-plugin-transform-jsx-html-template",
  "version": "0.1.0",
  "description": "Transforms JSX trees into lit-html template literals",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "babel-plugin",
    "lit",
    "jsx"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/litsxdev/litsx/tree/main/packages/babel-plugin-transform-jsx-html-template",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/babel-plugin-transform-jsx-html-template"
  },
  "peerDependencies": {
    "@babel/core": ">=7"
  },
  "dependencies": {
    "@babel/generator": "^7.26.5",
    "@babel/helper-plugin-utils": "^7.26.5",
    "@babel/plugin-syntax-jsx": "^7.26.5",
    "@babel/types": "^7.26.5"
  },
  "devDependencies": {
    "@babel/core": "^7.26.5"
  },
  "scripts": {
    "build": "../../node_modules/.bin/tsup src/index.js --format esm,cjs --out-dir dist --clean --external @babel/core --external @babel/types --external @babel/generator --external @babel/helper-plugin-utils --external @babel/plugin-syntax-jsx --external lit --external react --external typescript",
    "prepack": "yarn build"
  }
}
