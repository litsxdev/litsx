{
  "name": "@litsx/babel-plugin-litsx-proptypes",
  "version": "0.1.0",
  "description": "Lowers React propTypes assignments into native LitSX properties hoists",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "babel-plugin",
    "lit",
    "prop-types"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/litsxdev/litsx/tree/main/packages/babel-plugin-litsx-proptypes",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/babel-plugin-litsx-proptypes"
  },
  "peerDependencies": {
    "@babel/core": "^8.0.0-0"
  },
  "dependencies": {
    "@litsx/prop-types": "^0.1.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.0-rc.4"
  },
  "scripts": {
    "build": "../../node_modules/.bin/tsup src/index.js --format cjs --out-dir dist --clean --external @babel/core --external @babel/types --external @babel/generator --external @babel/helper-plugin-utils --external @babel/plugin-syntax-jsx --external lit --external react --external typescript",
    "prepack": "yarn build"
  }
}
