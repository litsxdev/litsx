{
  "name": "@litsx/babel-plugin-litsx-proptypes",
  "version": "0.2.4",
  "description": "Lowers React propTypes assignments into native LitSX properties hoists",
  "author": "LitSX Team",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "babel-plugin",
    "lit",
    "prop-types"
  ],
  "license": "Apache-2.0",
  "homepage": "https://litsx.dev/",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/babel-plugin-litsx-proptypes"
  },
  "peerDependencies": {
    "@babel/core": ">=7"
  },
  "dependencies": {
    "@babel/helper-plugin-utils": "^7.28.6",
    "@litsx/prop-types": "^0.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0"
  },
  "scripts": {
    "build": "../../node_modules/.bin/rollup --config rollup.config.js",
    "prepack": "yarn build"
  }
}
