{
  "name": "@litsx/vite-plugin",
  "version": "0.2.3",
  "description": "Official Vite plugin for LitSX compilation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "litsx",
    "vite",
    "plugin",
    "lit",
    "jsx"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/litsxdev/litsx/tree/main/packages/vite-plugin",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/vite-plugin"
  },
  "peerDependencies": {
    "vite": "^7.3.2 || ^8.0.0"
  },
  "dependencies": {
    "@litsx/compiler": "^0.3.0"
  },
  "scripts": {
    "build": "../../node_modules/.bin/rollup --config rollup.config.mjs",
    "prepack": "yarn build"
  }
}
