{
  "name": "prettier-plugin-litsx",
  "version": "0.3.4",
  "description": "Official Prettier plugin for LitSX-authored source",
  "author": "LitSX Team",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "prettier",
    "prettier-plugin",
    "litsx",
    "jsx",
    "typescript"
  ],
  "license": "Apache-2.0",
  "homepage": "https://litsx.dev/",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/prettier-plugin-litsx"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@litsx/authoring": "^0.5.0"
  },
  "scripts": {
    "build": "../../node_modules/.bin/rollup --config rollup.config.js",
    "prepack": "yarn build"
  }
}
