{
  "name": "@litsx/playground",
  "version": "0.1.0",
  "description": "Litsx playground component, preview runtime wiring, and worker integration",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./playground-runtime": {
      "import": "./dist/playground-runtime.js",
      "default": "./dist/playground-runtime.js"
    },
    "./worker": {
      "import": "./dist/litsx-playground.worker.js",
      "default": "./dist/litsx-playground.worker.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/litsx/litsx/tree/main/packages/litsx-playground",
  "bugs": {
    "url": "https://github.com/litsx/litsx/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsx/litsx.git",
    "directory": "packages/litsx-playground"
  },
  "scripts": {
    "build": "rollup --config rollup.config.mjs",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@babel/standalone": "^7.26.5",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@litsx/babel-plugin-transform-jsx-html-template": "workspace:^",
    "@litsx/babel-preset-litsx": "workspace:^",
    "codemirror": "^6.0.2",
    "litsx": "workspace:^"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "rollup": "^4.60.1"
  }
}
