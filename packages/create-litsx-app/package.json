{
  "name": "create-litsx-app",
  "version": "0.2.6",
  "description": "Scaffold a LitSX project with the recommended editor and build setup",
  "type": "module",
  "bin": "./dist/create-litsx-app.js",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "litsx",
    "scaffold",
    "vite",
    "lit",
    "jsx"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/litsxdev/litsx/tree/main/packages/create-litsx-app",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/create-litsx-app"
  },
  "scripts": {
    "build": "node ../../scripts/release/sync-scaffold-package-versions.mjs && ../../node_modules/.bin/rollup --config rollup.config.mjs",
    "prepack": "yarn build"
  }
}
