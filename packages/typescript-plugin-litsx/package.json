{
  "name": "@litsx/typescript-plugin",
  "version": "0.1.0",
  "description": "TypeScript language-service support for Litsx JSX syntax",
  "author": "Litsx Team",
  "homepage": "https://github.com/litsxdev/litsx/tree/main/packages/typescript-plugin-litsx",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "typescript",
    "tsserver",
    "jsx",
    "lit",
    "litsx"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/typescript-plugin-litsx"
  },
  "type": "module",
  "main": "./tsserver-plugin.cjs",
  "module": "./dist/index.js",
  "bin": {
    "litsx-tsc": "./dist/litsx-tsc.js"
  },
  "exports": {
    ".": {
      "require": "./tsserver-plugin.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./authored-semantics": {
      "require": "./dist/authored-semantics.cjs",
      "import": "./dist/authored-semantics.js",
      "default": "./dist/authored-semantics.js"
    },
    "./virtual-source": {
      "require": "./dist/virtual-source.cjs",
      "import": "./dist/virtual-source.js",
      "default": "./dist/virtual-source.js"
    },
    "./typecheck": {
      "require": "./dist/typecheck.cjs",
      "import": "./dist/typecheck.js",
      "default": "./dist/typecheck.js"
    }
  },
  "files": [
    "dist",
    "tsserver-plugin.cjs",
    "README.md"
  ],
  "dependencies": {
    "@babel/parser": "^7.28.5"
  },
  "peerDependencies": {
    "typescript": ">=5"
  },
  "scripts": {
    "build": "../../node_modules/.bin/rollup --config rollup.config.mjs",
    "prepack": "yarn build"
  }
}
