{
  "name": "@litsx/compiler",
  "version": "0.3.0",
  "description": "Build-facing LitSX compilation facade with correct parser and sourcemap handling",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    },
    "./authored-input": {
      "types": "./src/authored-input.d.ts",
      "import": "./src/authored-input.js",
      "require": "./dist/authored-input.cjs",
      "default": "./src/authored-input.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "litsx",
    "compiler",
    "babel",
    "vite",
    "jsx"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/litsxdev/litsx/tree/main/packages/compiler",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/compiler"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/parser": "^7.29.3",
    "@litsx/babel-plugin-transform-jsx-html-template": "^0.3.0",
    "@litsx/babel-preset-litsx": "^0.3.0",
    "@litsx/jsx-authoring": "^0.2.1",
    "@litsx/typescript-session": "^0.2.1"
  },
  "scripts": {
    "build": "../../node_modules/.bin/rollup --config rollup.config.js",
    "prepack": "yarn build"
  }
}
