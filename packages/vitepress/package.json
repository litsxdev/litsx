{
  "name": "@litsx/vitepress",
  "version": "0.0.0",
  "private": true,
  "description": "Internal VitePress integration for the LitSX website",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "default": "./src/index.js"
    },
    "./theme": {
      "default": "./src/theme/index.js"
    },
    "./versions": {
      "default": "./src/versions.js"
    },
    "./shiki-litsx-languages": {
      "default": "./src/shiki-litsx-languages.js"
    },
    "./styles.css": "./src/styles.css",
    "./theme/DocsVersionBanner": {
      "default": "./src/theme/DocsVersionBanner.js"
    },
    "./theme/DocsVersionSelect": {
      "default": "./src/theme/DocsVersionSelect.js"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/vitepress"
  },
  "peerDependencies": {
    "vitepress": ">=1",
    "vue": ">=3"
  },
  "dependencies": {
    "@litsx/compiler": "workspace:^",
    "@litsx/shiki-languages": "workspace:^"
  },
  "scripts": {
    "build": "node -e 'process.exit(0)'"
  }
}
