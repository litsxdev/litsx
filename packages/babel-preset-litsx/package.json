{
  "name": "@litsx/babel-preset-litsx",
  "version": "0.10.0",
  "description": "Canonical native Babel preset for LitSX-authored source",
  "author": "LitSX Team",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    },
    "./pipeline": {
      "import": "./src/pipeline.js",
      "require": "./dist/pipeline.cjs",
      "default": "./src/pipeline.js"
    },
    "./internal/transform-litsx-components": {
      "import": "./src/internal/transform-litsx-components.js",
      "require": "./dist/internal/transform-litsx-components.cjs",
      "default": "./src/internal/transform-litsx-components.js"
    },
    "./internal/transform-litsx-renderer-props": {
      "import": "./src/internal/transform-litsx-renderer-props.js",
      "require": "./dist/internal/transform-litsx-renderer-props.cjs",
      "default": "./src/internal/transform-litsx-renderer-props.js"
    },
    "./internal/transform-litsx-dom-refs": {
      "import": "./src/internal/transform-litsx-dom-refs.js",
      "require": "./dist/internal/transform-litsx-dom-refs.cjs",
      "default": "./src/internal/transform-litsx-dom-refs.js"
    },
    "./internal/transform-litsx-hooks": {
      "import": "./src/internal/transform-litsx-hooks.js",
      "require": "./dist/internal/transform-litsx-hooks.cjs",
      "default": "./src/internal/transform-litsx-hooks.js"
    },
    "./internal/transform-litsx-properties": {
      "import": "./src/internal/transform-litsx-properties.js",
      "require": "./dist/internal/transform-litsx-properties.cjs",
      "default": "./src/internal/transform-litsx-properties.js"
    },
    "./internal/transform-litsx-static-ir": {
      "import": "./src/internal/transform-litsx-static-ir.js",
      "require": "./dist/internal/transform-litsx-static-ir.cjs",
      "default": "./src/internal/transform-litsx-static-ir.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "babel-preset",
    "litsx",
    "babel",
    "lit"
  ],
  "license": "Apache-2.0",
  "homepage": "https://litsx.dev/",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/babel-preset-litsx"
  },
  "peerDependencies": {
    "@babel/core": ">=7"
  },
  "dependencies": {
    "@babel/helper-plugin-utils": "^7.29.7",
    "@babel/plugin-syntax-jsx": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@litsx/authoring": "^0.5.0",
    "@litsx/babel-parser": "^0.2.5",
    "@litsx/babel-plugin-shared-hooks": "^0.5.0",
    "@litsx/babel-plugin-transform-jsx-html-template": "^0.3.6",
    "@litsx/babel-plugin-transform-litsx-scoped-elements": "^0.4.5",
    "@litsx/typescript-session": "^0.2.3"
  },
  "scripts": {
    "build": "../../node_modules/.bin/rollup --config rollup.config.js",
    "prepack": "yarn build"
  }
}
