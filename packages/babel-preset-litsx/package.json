{
  "name": "@litsx/babel-preset-litsx",
  "version": "0.1.0",
  "description": "Canonical native Babel preset for LitSX-authored source",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "babel-preset",
    "litsx",
    "babel",
    "lit"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/litsxdev/litsx/tree/main/packages/babel-preset-litsx",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/babel-preset-litsx"
  },
  "peerDependencies": {
    "@babel/core": ">=7"
  },
  "dependencies": {
    "@babel/helper-plugin-utils": "^7.26.5",
    "@babel/plugin-syntax-jsx": "^7.26.5",
    "@litsx/babel-plugin-shared-hooks": "workspace:^",
    "@litsx/babel-plugin-transform-jsx-html-template": "workspace:^",
    "@litsx/babel-plugin-transform-litsx-scoped-elements": "workspace:^",
    "@litsx/typescript-session": "workspace:^"
  },
  "scripts": {
    "build": "../../node_modules/.bin/rollup --config rollup.config.mjs",
    "prepack": "yarn build"
  }
}
