{
  "name": "@litsx/babel-preset-react-compat",
  "version": "0.5.4",
  "description": "Canonical React compatibility pipeline for migrating React-authored source onto LitSX",
  "author": "LitSX Team",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "babel-preset",
    "react",
    "litsx",
    "migration"
  ],
  "license": "Apache-2.0",
  "homepage": "https://litsx.dev/",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/babel-preset-react-compat"
  },
  "peerDependencies": {
    "@babel/core": ">=7"
  },
  "dependencies": {
    "@babel/helper-plugin-utils": "^7.29.7",
    "@babel/plugin-syntax-jsx": "^7.29.7",
    "@litsx/babel-plugin-litsx-proptypes": "^0.2.0",
    "@litsx/babel-plugin-shared-hooks": "^0.6.3",
    "@litsx/babel-plugin-transform-jsx-html-template": "^0.3.5",
    "@litsx/babel-plugin-transform-litsx-scoped-elements": "^0.4.7",
    "@litsx/babel-preset-litsx": "^0.13.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7"
  },
  "scripts": {
    "build": "../../node_modules/.bin/rollup --config rollup.config.js",
    "prepack": "yarn build"
  }
}
