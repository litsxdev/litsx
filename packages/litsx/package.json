{
  "name": "litsx",
  "version": "0.1.0",
  "description": "Native Litsx runtime primitives, JSX runtime entrypoints, and web component utilities",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    },
    "./jsx-runtime": {
      "types": "./src/jsx-runtime.d.ts",
      "import": "./src/jsx-runtime.js",
      "require": "./dist/jsx-runtime.cjs",
      "default": "./src/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./src/jsx-dev-runtime.d.ts",
      "import": "./src/jsx-dev-runtime.js",
      "require": "./dist/jsx-dev-runtime.cjs",
      "default": "./src/jsx-dev-runtime.js"
    },
    "./runtime-infrastructure": {
      "types": "./src/runtime-infrastructure/index.d.ts",
      "import": "./src/runtime-infrastructure/index.js",
      "require": "./dist/runtime-infrastructure/index.cjs",
      "default": "./src/runtime-infrastructure/index.js"
    },
    "./context": {
      "types": "./src/context.d.ts",
      "import": "./src/context.js",
      "require": "./dist/context.cjs",
      "default": "./src/context.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "litsx",
    "lit",
    "jsx",
    "web-components"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/litsxdev/litsx/tree/main/packages/litsx",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/litsx"
  },
  "peerDependencies": {
    "lit": ">=3"
  },
  "dependencies": {
    "@lit/context": "^1.1.6",
    "@litsx/light-dom-registry": "workspace:^",
    "@open-wc/scoped-elements": "^3.0.6"
  },
  "devDependencies": {
    "lit": "^3.2.1"
  },
  "scripts": {
    "build": "../../node_modules/.bin/rollup --config rollup.config.mjs",
    "prepack": "yarn build"
  }
}
