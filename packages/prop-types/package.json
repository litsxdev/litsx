{
  "name": "@litsx/prop-types",
  "version": "0.2.1",
  "description": "Runtime helper support for React propTypes compatibility in LitSX",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    },
    "./runtime": {
      "import": "./src/runtime.js",
      "require": "./dist/runtime.cjs",
      "default": "./src/runtime.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "lit",
    "prop-types",
    "lithelement"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/litsxdev/litsx/tree/main/packages/prop-types",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/prop-types"
  },
  "scripts": {
    "build": "../../node_modules/.bin/rollup --config rollup.config.mjs",
    "prepack": "yarn build"
  }
}
