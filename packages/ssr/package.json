{
  "name": "@litsx/ssr",
  "version": "0.1.0",
  "description": "Scoped SSR runtime for LitSX",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "../../node_modules/.bin/rollup --config rollup.config.js",
    "prepack": "yarn build"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/litsxdev/litsx/tree/main/packages/ssr",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/ssr"
  },
  "peerDependencies": {
    "lit": ">=3",
    "vite": "^7.3.2 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@lit-labs/ssr": "^4.0.0",
    "@litsx/compiler": "workspace:*",
    "@litsx/core": "workspace:*",
    "@litsx/vite-plugin": "workspace:*"
  },
  "devDependencies": {
    "lit": "^3.2.1"
  }
}
