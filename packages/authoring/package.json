{
  "name": "@litsx/authoring",
  "version": "0.5.0",
  "description": "Shared LitSX authored syntax utilities for parser and tooling integrations",
  "author": "LitSX Team",
  "homepage": "https://litsx.dev/",
  "bugs": {
    "url": "https://github.com/litsxdev/litsx/issues"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/litsxdev/litsx.git",
    "directory": "packages/authoring"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    },
    "./parser": {
      "import": "./src/parser.js",
      "require": "./dist/parser.cjs",
      "default": "./src/parser.js"
    }
  },
  "dependencies": {
    "magic-string": "^0.30.21"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "../../node_modules/.bin/rollup --config rollup.config.js",
    "prepack": "yarn build"
  }
}
