{
  "name": "litsx-workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.10.3",
  "workspaces": [
    "packages/babel-parser-litsx",
    "packages/babel-plugin-litsx-proptypes",
    "packages/babel-plugin-shared-hooks",
    "packages/babel-plugin-transform-jsx-html-template",
    "packages/babel-plugin-transform-litsx-scoped-elements",
    "packages/babel-preset-litsx",
    "packages/babel-preset-react-compat",
    "packages/compiler",
    "packages/create-litsx-app",
    "packages/eslint-plugin-litsx",
    "packages/jsx-authoring",
    "packages/light-dom-registry",
    "packages/litsx",
    "packages/litsx-playground",
    "packages/prettier-plugin-litsx",
    "packages/prop-types",
    "packages/typescript-plugin-litsx",
    "packages/typescript-session",
    "packages/vite-plugin",
    "packages/vitepress",
    "packages/vscode-litsx"
  ],
  "devDependencies": {
    "@babel/core": "^7.26.5",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/plugin-syntax-jsx": "^7.27.1",
    "@babel/plugin-syntax-typescript": "^7.27.1",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@babel/standalone": "^7.26.5",
    "@changesets/cli": "^2.31.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@open-wc/scoped-elements": "^3.0.6",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vscode/vsce": "^3.9.1",
    "codemirror": "^6.0.2",
    "diff": "^8.0.2",
    "eslint": "^9.26.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.2",
    "magic-string": "^0.30.21",
    "prettier": "^3.8.3",
    "rollup": "^4.60.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vite": "^8.0.3",
    "vite-plugin-babel": "^1.6.0",
    "vitepress": "^1.6.3",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "yarn workspaces run build",
    "playground:build": "rollup --config packages/litsx-playground/rollup.config.mjs",
    "playground:runtime": "yarn playground:build",
    "test": "vitest run",
    "test:transforms": "LITSX_VITEST_TRANSFORMS=1 vitest run",
    "bench:transform-litsx": "node scripts/bench/transform-litsx.mjs",
    "coverage": "vitest run --coverage",
    "docs:framework": "node scripts/docs/build-framework-docs.mjs",
    "docs:reference": "node scripts/docs/build-reference-docs.mjs",
    "docs:transforms": "node scripts/docs/build-transform-docs.mjs",
    "docs:build-content": "node scripts/docs/build-site-content.mjs",
    "docs:dev": "yarn playground:build && yarn docs:build-content && vitepress dev website/docs",
    "docs:build": "yarn playground:build && yarn docs:build-content && vitepress build website/docs",
    "docs:preview": "vitepress preview website/docs",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "node scripts/release/changeset-version.mjs",
    "changeset:publish": "changeset publish",
    "release:build:public": "node scripts/release/build-public-packages.mjs",
    "release:check": "yarn release:build:public && node scripts/release/check-release-packages.mjs",
    "release:smoke:scaffolds": "node scripts/release/smoke-scaffolds.mjs",
    "release:artifacts": "node scripts/release/build-release-artifacts.mjs",
    "release:publish": "yarn release:check && yarn release:smoke:scaffolds && yarn release:test && yarn changeset:publish",
    "release:test": "vitest run test/create-litsx-app.test.js test/prettier-plugin-litsx.test.js test/vscode-litsx.test.js test/vitepress-package.test.js test/typescript-plugin-litsx.test.js test/vite-plugin.test.js test/compiler.test.js test/compiler-authored-input.test.js",
    "release:vscode:build": "yarn workspace vscode-litsx build",
    "release:vscode:package": "yarn workspace vscode-litsx package:vsix"
  },
  "author": "",
  "license": "Apache-2.0",
  "description": ""
}
