{
  "name": "litsx-workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/shared/*"
  ],
  "devDependencies": {
    "@babel/core": "^7.26.5",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/plugin-syntax-jsx": "^7.27.1",
    "@babel/plugin-syntax-typescript": "^7.27.1",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@babel/standalone": "^7.26.5",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@open-wc/scoped-elements": "^3.0.6",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "codemirror": "^6.0.2",
    "diff": "^8.0.2",
    "eslint": "^9.26.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.2",
    "magic-string": "^0.30.21",
    "rollup": "^4.60.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vite": "^7.1.7",
    "vite-plugin-babel": "^1.6.0",
    "vitepress": "^1.6.3",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "yarn workspaces run build",
    "playground:build": "rollup --config packages/litsx-playground/rollup.config.mjs",
    "playground:runtime": "yarn playground:build",
    "test": "vitest run",
    "test:transforms": "LITSX_VITEST_TRANSFORMS=1 vitest run",
    "bench:transform-litsx": "node scripts/bench/transform-litsx.mjs",
    "coverage": "vitest run --coverage",
    "docs:framework": "node scripts/docs/build-framework-docs.mjs",
    "docs:reference": "node scripts/docs/build-reference-docs.mjs",
    "docs:transforms": "node scripts/docs/build-transform-docs.mjs",
    "docs:build-content": "node scripts/docs/build-site-content.mjs",
    "docs:dev": "yarn playground:build && yarn docs:build-content && vitepress dev website/docs",
    "docs:build": "yarn playground:build && yarn docs:build-content && vitepress build website/docs",
    "docs:preview": "vitepress preview website/docs"
  },
  "author": "",
  "license": "Apache-2.0",
  "description": ""
}
