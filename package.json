{
  "name": "litsx-workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.10.3",
  "workspaces": [
    "packages/babel-parser-litsx",
    "packages/babel-plugin-litsx-proptypes",
    "packages/babel-plugin-shared-hooks",
    "packages/babel-plugin-transform-jsx-html-template",
    "packages/babel-plugin-transform-litsx-scoped-elements",
    "packages/babel-preset-litsx",
    "packages/babel-preset-react-compat",
    "packages/compiler",
    "packages/create-litsx-app",
    "packages/eslint-plugin-litsx",
    "packages/jsx-authoring",
    "packages/light-dom-registry",
    "packages/litsx",
    "packages/prettier-plugin-litsx",
    "packages/prop-types",
    "packages/shiki-languages",
    "packages/typescript-plugin-litsx",
    "packages/typescript-session",
    "packages/vite-plugin"
  ],
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/plugin-syntax-jsx": "^7.28.6",
    "@babel/plugin-syntax-typescript": "^7.27.1",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@changesets/cli": "^2.31.0",
    "@open-wc/scoped-elements": "^3.0.6",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "diff": "^9.0.0",
    "eslint": "^9.26.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "magic-string": "^0.30.21",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vite": "^8.0.11",
    "vite-plugin-babel": "^1.6.0",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "build": "yarn workspaces run build",
    "test": "vitest run",
    "test:transforms": "LITSX_VITEST_TRANSFORMS=1 vitest run",
    "bench:transform-litsx": "node scripts/bench/transform-litsx.js",
    "coverage": "vitest run --coverage",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "release:check:internal-ranges": "node scripts/release/check-internal-dependency-ranges.js",
    "release:preflight-local": "yarn install --mode=skip-build && yarn release:check:internal-ranges && yarn changeset:status && node scripts/release/check-release-packages.js",
    "changeset:version": "node scripts/release/changeset-version.js",
    "changeset:publish": "changeset publish",
    "release:build:public": "node scripts/release/build-public-packages.js",
    "release:check": "yarn release:build:public && node scripts/release/check-release-packages.js",
    "hooks:install": "node scripts/hooks/install-hooks.mjs",
    "release:smoke:scaffolds": "node scripts/release/smoke-scaffolds.js",
    "release:artifacts": "node scripts/release/build-release-artifacts.js",
    "release:github": "node scripts/release/build-github-release.js",
    "release:github:backfill": "node scripts/release/backfill-github-releases.js",
    "release:publish": "yarn release:check && yarn release:smoke:scaffolds && yarn release:test && yarn changeset:publish",
    "release:test": "vitest run test/create-litsx-app.test.js test/prettier-plugin-litsx.test.js test/shiki-languages.test.js test/typescript-plugin-litsx.test.js test/vite-plugin.test.js test/compiler.test.js test/compiler-authored-input.test.js"
  },
  "author": "",
  "license": "Apache-2.0",
  "description": ""
}
