{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "maxNodeModuleJsDepth": 0,
    "jsx": "react-jsx",
    "jsxImportSource": "@litsx/core",
    "checkJs": true,
    "plugins": [
      {
        "name": "@litsx/typescript"
      }
    ]
  },
  "include": [
    "src"
  ]
}
